      "decisions.md": "## Adopt OAuth 2.0 with PKCE #auth\nThe login flow uses OAuth 2.0 with PKCE and short-lived tokens.\n"
    }
  },
  "session": [
    {
      "name": "initialize handshake",
      "request": {
        "jsonrpc": "2.0",
        "id": 1,
        "method": "initialize",
        "params": {
          "protocolVersion": "2025-03-26",
          "capabilities": {},
          "clientInfo": { "name": "smoke-client", "version": "0.0.0" }
        }
      },
      "expect": {
        "status": 200,
        "json.result.protocolVersion": "2025-03-26",
        "json.result.serverInfo.name": "agentctx"
      }

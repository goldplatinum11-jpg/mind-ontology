{
  "name": "mind-ontology",
  "version": "0.1.0",
  "description": "Mind Ontology — compile AGENTS.md, CLAUDE.md, and live task-scoped context packs from one git-native Markdown ontology. Local-first OSS context compiler + MCP server.",
  "license": "Apache-2.0",
  "keywords": [
    "agents",
    "agents-md",
    "claude-md",
    "context",
    "context-engineering",
    "mcp",
    "ontology",
    "cli"
  ],
  "files": [
    "scripts/agentctx/**",
    "templates/**",
    "README.md",
    "LICENSE",
    "NOTICE",
    "docs/mind-ontology-quickstart.md",
    "docs/mind-ontology-quickstart-examples-v0.md",
    "docs/agent-setup.md",
    "docs/agentctx-mcp.md",
    "docs/agentctx-mcp-setup.md",
    "docs/cli-errors.md",
    "docs/init-from-repo.md",
    "docs/schema-authoring.md",
    "docs/testing.md"
  ],
  "bin": {
    "mind-ontology": "scripts/agentctx/cli.mjs"
  },
  "scripts": {
    "test": "vitest run tests/unit",
    "mind-ontology": "node scripts/agentctx/cli.mjs",
    "agentctx:compile": "node scripts/agentctx/compile.mjs compile",
    "agentctx:init": "node scripts/agentctx/init.mjs",
    "agentctx:mcp": "node scripts/agentctx/mcp-server.mjs",
    "agentctx:proof": "vitest run tests/unit/agentctx-proof.test.mjs",
    "agentctx:smoke": "node scripts/agentctx/acceptance-smoke.mjs",
    "agentctx:validate": "node scripts/agentctx/schema.mjs",
    "agentctx:metrics": "node scripts/agentctx/metrics.mjs"
  },
  "devDependencies": {
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20"
  }
}
